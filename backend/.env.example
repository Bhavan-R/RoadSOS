# Copy this file to .env and fill in your values.

# Required: Google Gemini API key for AI triage and dispatch summary.
# Free tier: 60 RPM, 1500 RPD on gemini-2.0-flash. No billing required.
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Optional: Google Places API key for OSM fallback / phone enrichment.
# Without this, OSM-only results are used (fine for dense regions).
# Multi-key rotation supported: comma-separated values.
Mapsplatformkey=AIza...
